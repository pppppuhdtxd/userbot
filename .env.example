# .env.example
# =============
# Copy this file to .env and fill in your values.
# Values set here override environment variables of the same name.
# All fields are OPTIONAL — defaults are shown in brackets.

# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level printed to console and written to log files.
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# ── Proxy ─────────────────────────────────────────────────────────────────────

# Path to the MTProxy list file, relative to the userbot/ directory.
# PROXY_FILE=proxies.txt

# ── Reconnect back-off ────────────────────────────────────────────────────────

# Initial back-off in seconds after a failed connection attempt.
# BACKOFF_START=1

# Maximum back-off in seconds (exponential, capped at this value).
# BACKOFF_MAX=300

# ── History scanning ──────────────────────────────────────────────────────────

# Maximum number of messages fetched by clearer / auto_clearer.
# HISTORY_LIMIT=2000
