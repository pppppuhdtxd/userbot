# ==========================================
# Accounts & Sensitive Data
# ==========================================
# Ignore entire accounts folder to protect sessions and configs
accounts/
# Keep the folder structure in git using .gitkeep
!accounts/.gitkeep

# Ignore specific sensitive files anywhere
*.session
.env
.env.*
account.json

# ==========================================
# Data Directory (Logs, Cache, Settings)
# ==========================================
data/
!data/.gitkeep

# ==========================================
# Python & Virtual Environments
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/

# ==========================================
# Logs & Temporary Files
# ==========================================
*.log
*.tmp
*.bak
*.swp

# ==========================================
# IDE & OS Generated Files
# ==========================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db